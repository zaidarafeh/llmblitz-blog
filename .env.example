# Sanity project — get these from sanity.io/manage → your project → Settings → API
PUBLIC_SANITY_PROJECT_ID=your_project_id_here
PUBLIC_SANITY_DATASET=production

# Only needed when running the migration script (scripts/migrate.mjs)
# Create an Editor token at: sanity.io/manage → API → Tokens
SANITY_TOKEN=your_editor_token_here
SANITY_PROJECT_ID=your_project_id_here
