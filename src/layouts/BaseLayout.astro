---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Practical prompt engineering insights from the team at LLMBlitz.io.',
  canonicalUrl = Astro.url.href,
  ogImage = 'https://llmblitz.io/og-home.png',
} = Astro.props;

const fullTitle = title === 'LLMBlitz Blog'
  ? 'LLMBlitz Blog — Prompt Engineering Insights'
  : `${title} — LLMBlitz Blog`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1280" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Roboto+Mono:wght@400;500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

  </head>
  <body>
    <div class="app-shell" style="min-height:100vh;display:flex;flex-direction:column;">

      <!-- ── Header ── -->
      <header class="header">
        <a href="https://llmblitz.io" class="header-brand" aria-label="LLMBlitz home">
          <svg class="header-logo-svg" viewBox="0 0 122 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <svg x="0" y="3" width="11" height="26" viewBox="32 6 56 118">
              <defs>
                <clipPath id="hdr-bolt-clip">
                  <polygon points="68,6 32,70 56,70 52,124 88,60 64,60"/>
                </clipPath>
              </defs>
              <g clip-path="url(#hdr-bolt-clip)">
                <rect x="32" y="6"   width="56" height="9" fill="#22c55e" opacity="0.9"/>
                <rect x="32" y="16"  width="40" height="9" fill="#22c55e" opacity="0.65"/>
                <rect x="32" y="26"  width="52" height="9" fill="#eab308" opacity="0.85"/>
                <rect x="32" y="36"  width="30" height="9" fill="#f97316" opacity="0.80"/>
                <rect x="32" y="46"  width="56" height="9" fill="#22c55e" opacity="0.90"/>
                <rect x="32" y="56"  width="44" height="9" fill="#ef4444" opacity="0.75"/>
                <rect x="32" y="66"  width="36" height="9" fill="#eab308" opacity="0.80"/>
                <rect x="32" y="76"  width="56" height="9" fill="#22c55e" opacity="0.70"/>
                <rect x="32" y="86"  width="28" height="9" fill="#f97316" opacity="0.75"/>
                <rect x="32" y="96"  width="48" height="9" fill="#22c55e" opacity="0.85"/>
                <rect x="32" y="106" width="34" height="9" fill="#eab308" opacity="0.65"/>
                <rect x="32" y="116" width="56" height="9" fill="#22c55e" opacity="0.90"/>
              </g>
              <polygon points="68,6 32,70 56,70 52,124 88,60 64,60" fill="none" stroke="#fff" stroke-width="3" stroke-linejoin="round" opacity="0.9"/>
            </svg>
            <text x="15" y="23" font-family="'Orbitron', monospace" font-size="13" font-weight="700" fill="white" letter-spacing="1">LLMBlitz<tspan fill="#22c55e">.io</tspan></text>
            <rect class="header-cursor" x="107" y="10" width="2" height="13" fill="#22c55e"/>
          </svg>
        </a>

        <nav class="header-nav">
          <a href="https://llmblitz.io/optimize">BlitzLab</a>
          <a href="https://llmblitz.io/prompt-surgeon">Prompt Designer</a>
          <a href="https://llmblitz.io/eco-blitz">EcoBlitz</a>
          <a href="https://blog.llmblitz.io" class="active">Blog</a>
        </nav>

        <div class="header-spacer"></div>

        <a href="https://llmblitz.io" class="header-cta">Try LLMBlitz free →</a>
      </header>

      <!-- ── Page content ── -->
      <main style="flex:1;">
        <slot />
      </main>

      <!-- ── Footer ── -->
      <footer class="site-footer">
        <div class="footer-inner">
          © {new Date().getFullYear()} LLMBlitz.io — AI Prompt Analysis &amp; Optimization ·
          <a href="https://llmblitz.io">App</a> ·
          <a href="https://llmblitz.io/upgrade">Pricing</a> ·
          <a href="mailto:hello@llmblitz.io">hello@llmblitz.io</a>
        </div>
      </footer>

    </div>
  </body>
</html>
