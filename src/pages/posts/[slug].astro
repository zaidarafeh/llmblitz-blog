---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient, ALL_SLUGS_QUERY, POST_QUERY } from '../../lib/sanity';
import type { PostFull } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const slugs: { slug: string }[] = await sanityClient.fetch(ALL_SLUGS_QUERY);
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post: PostFull | null = await sanityClient.fetch(POST_QUERY, { slug });

if (!post) return Astro.redirect('/404');

const {
  title,
  description,
  publishedAt,
  tags,
  tool,
  toolHref,
  body,
} = post;

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

function escapeHtml(str: string) {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

const bodyHtml = toHTML(body ?? [], {
  components: {
    types: {
      codeBlock: ({ value }: any) =>
        `<pre class="code-block" data-lang="${value.language ?? 'text'}"><code>${escapeHtml(value.code ?? '')}</code></pre>`,

      callout: ({ value }: any) =>
        `<div class="callout callout--${value.style ?? 'info'}">${escapeHtml(value.content ?? '')}</div>`,

      imageBlock: ({ value }: any) => {
        const src = value.image?.asset?.url ?? '';
        const alt = escapeHtml(value.alt ?? '');
        const caption = value.caption ? `<figcaption>${escapeHtml(value.caption)}</figcaption>` : '';
        const img = `<img src="${src}" alt="${alt}" loading="lazy" />`;
        const inner = value.href ? `<a href="${value.href}" target="_blank" rel="noopener">${img}</a>` : img;
        return `<figure class="post-image">${inner}${caption}</figure>`;
      },

      table: ({ value }: any) => {
        const rows: any[] = value.rows ?? [];
        if (!rows.length) return '';
        const [head, ...body] = rows;
        const thCells = (head?.cells ?? []).map((c: string) => `<th>${escapeHtml(c)}</th>`).join('');
        const bodyRows = body.map((row: any) =>
          `<tr>${(row.cells ?? []).map((c: string) => `<td>${escapeHtml(c)}</td>`).join('')}</tr>`
        ).join('');
        return `<div class="table-wrapper"><table><thead><tr>${thCells}</tr></thead><tbody>${bodyRows}</tbody></table></div>`;
      },
    },
    marks: {
      link: ({ children, value }: any) => {
        const target = value.blank ? ' target="_blank" rel="noopener noreferrer"' : '';
        return `<a href="${value.href}"${target}>${children}</a>`;
      },
      code: ({ children }: any) => `<code class="inline-code">${children}</code>`,
    },
  },
});

const canonicalUrl = `https://blog.llmblitz.io/posts/${slug}`;
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>
  <article class="post-page">

    <header class="post-header">
      <div class="post-tags">
        {tags?.map((tag: string) => <span class="post-tag">{tag}</span>)}
      </div>
      <h1 class="post-h1">{title}</h1>
      <div class="post-meta">{fmtDate(publishedAt)}</div>
      <hr class="post-divider" />
    </header>

    <div class="post-body" set:html={bodyHtml} />

    {tool && toolHref && (
      <div class="post-cta">
        <div>
          <div class="post-cta-text">Try it yourself with {tool}</div>
          <div class="post-cta-sub">No setup required — paste your prompt and run.</div>
        </div>
        <a href={`https://llmblitz.io${toolHref}`} class="post-cta-btn">
          Open {tool} →
        </a>
      </div>
    )}

  </article>
</BaseLayout>
