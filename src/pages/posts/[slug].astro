---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient, ALL_SLUGS_QUERY, POST_QUERY } from '../../lib/sanity';
import type { PostFull } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const slugs: { slug: string }[] = await sanityClient.fetch(ALL_SLUGS_QUERY);
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post: PostFull | null = await sanityClient.fetch(POST_QUERY, { slug });

if (!post) return Astro.redirect('/404');

const {
  title,
  description,
  publishedAt,
  tags,
  tool,
  toolHref,
  body,
} = post;

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

function escapeHtml(str: string) {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

const bodyHtml = toHTML(body ?? [], {
  components: {
    types: {
      codeBlock: ({ value }: any) =>
        `<pre class="code-block" data-lang="${value.language ?? 'text'}"><code>${escapeHtml(value.code ?? '')}</code></pre>`,

      callout: ({ value }: any) =>
        `<div class="callout callout--${value.style ?? 'info'}">${escapeHtml(value.content ?? '')}</div>`,

      heroImage: ({ value }: any) => {
        const src = value.image?.asset?.url ?? '';
        const alt = escapeHtml(value.alt ?? '');
        const heights: Record<string, string> = { small: '300px', medium: '480px', large: '640px' };
        const h = heights[value.height ?? 'medium'];
        const overlay = (value.title || value.subtitle) ? `
          <div class="hero-overlay">
            ${value.title    ? `<div class="hero-overlay-title">${escapeHtml(value.title)}</div>`    : ''}
            ${value.subtitle ? `<div class="hero-overlay-sub">${escapeHtml(value.subtitle)}</div>` : ''}
          </div>` : '';
        return `<div class="hero-image" style="height:${h}">
          <img src="${src}" alt="${alt}" loading="lazy" />
          ${overlay}
        </div>`;
      },

      imagePair: ({ value }: any) => {
        const renderSide = (side: any) => {
          if (!side?.image?.asset?.url) return '<div class="image-pair-side"></div>';
          const caption = side.caption ? `<figcaption>${escapeHtml(side.caption)}</figcaption>` : '';
          return `<figure class="image-pair-side">
            <img src="${side.image.asset.url}" alt="${escapeHtml(side.alt ?? '')}" loading="lazy" />
            ${caption}
          </figure>`;
        };
        return `<div class="image-pair">${renderSide(value.left)}${renderSide(value.right)}</div>`;
      },

      imageText: ({ value }: any) => {
        const src = value.image?.asset?.url ?? '';
        const reversed = value.imagePosition === 'right' ? ' image-text--reversed' : '';
        const btn = value.button?.label && value.button?.href
          ? `<a href="${value.button.href}" class="image-text-btn"${value.button.newTab ? ' target="_blank" rel="noopener"' : ''}>${escapeHtml(value.button.label)}</a>`
          : '';
        return `<div class="image-text${reversed}">
          <div class="image-text-img"><img src="${src}" alt="${escapeHtml(value.alt ?? '')}" loading="lazy" /></div>
          <div class="image-text-body">
            ${value.heading ? `<h3>${escapeHtml(value.heading)}</h3>` : ''}
            ${value.body    ? `<p>${escapeHtml(value.body)}</p>`      : ''}
            ${btn}
          </div>
        </div>`;
      },

      ImageTextBlockType: ({ value }: any) => {
        const img = value.mainImage?.asset?.url
          ? `<img src="${value.mainImage.asset.url}" alt="${escapeHtml(value.mainImage.alt ?? '')}" loading="lazy" />`
          : '';
        const text = `
          ${value.title    ? `<h3>${escapeHtml(value.title)}</h3>` : ''}
          ${value.subTitle ? `<p class="image-text-subtitle">${escapeHtml(value.subTitle)}</p>` : ''}
          ${value.description ? toHTML(value.description, { components: {} }) : ''}
          ${value.button?.text ? `<a href="${value.button.link}" class="image-text-btn"${value.button.openInNewTab ? ' target="_blank" rel="noopener"' : ''}>${escapeHtml(value.button.text)}</a>` : ''}
        `;
        const reversed = value.imagePosition === 'right' ? ' image-text-block--reversed' : '';
        return `<div class="image-text-block${reversed}"><div class="image-text-img">${img}</div><div class="image-text-content">${text}</div></div>`;
      },

      imageBlock: ({ value }: any) => {
        const src = value.image?.asset?.url ?? '';
        const alt = escapeHtml(value.alt ?? '');
        const caption = value.caption ? `<figcaption>${escapeHtml(value.caption)}</figcaption>` : '';
        const img = `<img src="${src}" alt="${alt}" loading="lazy" />`;
        const inner = value.href ? `<a href="${value.href}" target="_blank" rel="noopener">${img}</a>` : img;
        return `<figure class="post-image">${inner}${caption}</figure>`;
      },

      richTableBlock: ({ value }: any) => {
        const rows: any[] = value.rows ?? [];
        const headers: any[] = value.columnHeaders ?? [];
        const hasColTitles = value.hasColumnTitles && headers.length > 0;
        if (!rows.length) return '';

        const renderCell = (cell: any) =>
          cell?.content?.length ? toHTML(cell.content, { components: {} }) : '';

        let thead = '';
        if (hasColTitles) {
          const ths = headers.map((h: any) => `<th>${escapeHtml(h.title ?? '')}</th>`).join('');
          thead = `<thead><tr>${ths}</tr></thead>`;
        }

        const bodyRows = rows.map((row: any) => {
          const cells = (row.cells ?? []).map((cell: any) => `<td>${renderCell(cell)}</td>`).join('');
          return `<tr>${cells}</tr>`;
        }).join('');

        return `<div class="table-wrapper"><table>${thead}<tbody>${bodyRows}</tbody></table></div>`;
      },
    },
    marks: {
      link: ({ children, value }: any) => {
        const target = value.blank ? ' target="_blank" rel="noopener noreferrer"' : '';
        return `<a href="${value.href}"${target}>${children}</a>`;
      },
      code: ({ children }: any) => `<code class="inline-code">${children}</code>`,
    },
  },
});

const canonicalUrl = `https://blog.llmblitz.io/posts/${slug}`;
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>
  <article class="post-page">

    <header class="post-header">
      <div class="post-tags">
        {tags?.map((tag: string) => <span class="post-tag">{tag}</span>)}
      </div>
      <h1 class="post-h1">{title}</h1>
      <div class="post-meta">{fmtDate(publishedAt)}</div>
      <hr class="post-divider" />
    </header>

    <div class="post-body" set:html={bodyHtml} />

    {tool && toolHref && (
      <div class="post-cta">
        <div>
          <div class="post-cta-text">Try it yourself with {tool}</div>
          <div class="post-cta-sub">No setup required — paste your prompt and run.</div>
        </div>
        <a href={`https://llmblitz.io${toolHref}`} class="post-cta-btn">
          Open {tool} →
        </a>
      </div>
    )}

  </article>
</BaseLayout>
