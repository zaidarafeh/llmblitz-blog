---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient, POSTS_QUERY } from '../lib/sanity';
import type { PostSummary } from '../lib/sanity';

const posts: PostSummary[] = await sanityClient.fetch(POSTS_QUERY);

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<BaseLayout
  title="LLMBlitz Blog"
  description="Practical prompt engineering insights — token-level analysis, cost optimization, and building reliable LLM pipelines."
>
  <div class="blog-page">
    <p class="blog-eyebrow">LLMBlitz.io</p>
    <h1 class="blog-title">Prompt Engineering,<br/>without the guesswork.</h1>
    <p class="blog-subtitle">
      Token-level breakdowns, cost teardowns, and practical guides for AI builders
      who ship to production.
    </p>

    <div class="post-list">
      {posts.map(post => (
        <a href={`/posts/${post.slug}`} class="post-card">
          <div class="post-card-tags">
            {post.tags?.map((tag: string) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
          <div class="post-card-title">{post.title}</div>
          <p class="post-card-excerpt">{post.description}</p>
          <div class="post-card-meta">{fmtDate(post.publishedAt)}</div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
